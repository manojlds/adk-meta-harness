# Default model for the ADK agent being optimized
# Overridden by --model flag or config.yaml
AMH_MODEL=openai/glm-5

# ADK agent API — model provider credentials
# The agent under optimization uses these to call the LLM
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://opencode.ai/zen/go/v1
OPENAI_BASE_URL=https://opencode.ai/zen/go/v1